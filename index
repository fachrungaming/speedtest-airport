<!DOCTYPE html>
<html class="dark" lang="id">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>AirportTech Speedtest - Futuristic HUD</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#00f7ff",
                        "tech-blue": "#0055ff",
                        "accent-green": "#0bda5b",
                        "background-dark": "#06090f",
                        "card-dark": "rgba(16, 25, 34, 0.4)",
                    },
                    fontFamily: {
                        "display": ["Space Grotesk"]
                    },
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400&display=swap');
        
        body {
            font-family: 'Space Grotesk', sans-serif;
            @apply bg-background-dark text-white overflow-x-hidden;
        }

        .font-mono { font-family: 'JetBrains Mono', monospace; }

        .hud-card {
            @apply bg-card-dark backdrop-blur-md border border-primary/20 rounded-xl relative overflow-hidden;
            box-shadow: 0 0 20px rgba(0, 247, 255, 0.05);
        }

        .hud-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 10px; height: 10px;
            border-top: 2px solid theme('colors.primary');
            border-left: 2px solid theme('colors.primary');
        }

        .hud-card::after {
            content: '';
            position: absolute;
            bottom: 0; right: 0; width: 10px; height: 10px;
            border-bottom: 2px solid theme('colors.primary');
            border-right: 2px solid theme('colors.primary');
        }

        .btn-tech-ring {
            @apply absolute w-60 h-60 rounded-full border border-primary/20;
            animation: rotate 10s linear infinite;
        }

        .btn-tech-ring::after {
            content: '';
            @apply absolute -top-1 left-1/2 w-2 h-2 bg-primary rounded-full shadow-[0_0_10px_#00f7ff];
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .glow-text {
            text-shadow: 0 0 15px rgba(0, 247, 255, 0.6);
        }

        .tech-grid {
            background-image: linear-gradient(rgba(0, 247, 255, 0.05) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(0, 247, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .console-log {
            @apply fixed left-4 top-1/2 -translate-y-1/2 w-48 hidden lg:flex flex-col gap-1 z-20 pointer-events-none opacity-40;
        }

        .boot-overlay {
            @apply fixed inset-0 z-[100] bg-black flex flex-col items-center justify-center font-mono text-primary text-xs transition-opacity duration-1000;
        }

        .scanline {
            width: 100%;
            height: 100px;
            z-index: 5;
            background: linear-gradient(0deg, rgba(0, 247, 255, 0) 0%, rgba(0, 247, 255, 0.1) 50%, rgba(0, 247, 255, 0) 100%);
            opacity: 0.1;
            position: absolute;
            bottom: 100%;
            animation: scanline 8s linear infinite;
        }

        @keyframes scanline {
            0% { bottom: 100%; }
            100% { bottom: -100px; }
        }
    </style>
</head>

<body class="min-h-screen flex flex-col relative">
    <!-- Boot Sequence -->
    <div id="bootOverlay" class="boot-overlay">
        <div class="w-64 space-y-2">
            <p id="bootText"></p>
            <div class="h-1 w-full bg-primary/10 rounded-full overflow-hidden">
                <div id="bootProgress" class="h-full bg-primary w-0 transition-all duration-100"></div>
            </div>
        </div>
    </div>

    <!-- Background Layer -->
    <div class="fixed inset-0 z-0 overflow-hidden">
        <!-- Static Airport Background -->
        <img src="bandara upg.jpg" class="absolute inset-0 w-full h-full object-cover opacity-25 mix-blend-screen"
            alt="Bandara Sultan Hasanuddin">

        <video autoplay muted loop playsinline class="w-full h-full object-cover opacity-30">
            <source
                src="https://assets.mixkit.co/videos/preview/mixkit-abstract-technology-elements-in-blue-9141-large.mp4"
                type="video/mp4">
        </video>

        <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px]"></div>
        <div class="tech-grid absolute inset-0 opacity-20"></div>
        <div class="scanline"></div>
    </div>

    <!-- Side Console Log -->
    <div class="console-log text-[7px] font-mono leading-tight">
        <p class="text-primary/80">>> INITIALIZING_NODE_TRACER</p>
        <p class="text-slate-500">>> ENCRYPTING_HANDSHAKE_SSL...</p>
        <p class="text-slate-500">>> SYNCING_GEOLOC_API...</p>
        <p id="liveLogLine" class="text-primary animate-pulse">> WAITING_FOR_PROTOCOL</p>
    </div>

    <header class="flex items-center justify-between px-6 pt-12 pb-4 relative z-20">
        <div class="flex items-center gap-3">
            <div class="bg-primary/20 p-2 rounded-lg border border-primary/40 backdrop-blur-md">
                <span class="material-symbols-outlined text-primary text-3xl glow-text">settings_input_component</span>
            </div>
            <div>
                <h1 class="text-xl font-black tracking-tighter text-white glow-text uppercase">AirportTech <span
                        class="text-primary">v2.0</span></h1>
                <p class="text-[8px] text-primary/60 font-black tracking-[0.3em] uppercase">Secure Node:
                    UPG-AIRPORT-MAIN</p>
            </div>
        </div>
        <div class="flex gap-4">
            <div class="flex flex-col items-end">
                <p class="text-[7px] font-mono text-primary/40 leading-none">STATUS: SECURITY_PASS</p>
                <p class="text-[7px] font-mono text-primary/40 mt-1 leading-none">NODE: IND-05-SOUTH</p>
            </div>
        </div>
    </header>

    <main class="flex-1 flex flex-col px-6 relative z-10 pb-12">
        <section class="flex flex-col sm:flex-row gap-4 py-6">
            <div class="hud-card flex-1 p-6 transition-all hover:bg-primary/5">
                <div class="flex items-center gap-2 mb-3 opacity-60">
                    <span class="material-symbols-outlined text-sm text-primary">router</span>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] leading-none text-primary">Penyedia
                        Jaringan</p>
                </div>
                <p class="text-2xl font-black tracking-tighter text-white">Airport Technology</p>
                <div class="flex items-center gap-1.5 mt-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-accent-green animate-pulse"></div>
                    <p class="text-accent-green text-[10px] font-black tracking-widest uppercase">(Upg Airport)</p>
                </div>
            </div>
            <div class="hud-card flex-1 p-6 transition-all hover:bg-primary/5">
                <div class="flex items-center gap-2 mb-3 opacity-60">
                    <span class="material-symbols-outlined text-sm text-primary">signal_cellular_alt</span>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] leading-none text-primary">Status
                        Jaringan</p>
                </div>
                <p class="text-2xl font-black tracking-tighter text-white">Free WiFi</p>
                <div class="flex items-center gap-1.5 mt-2">
                    <span class="material-symbols-outlined text-primary text-[12px]">sensors</span>
                    <p class="text-slate-400 text-[10px] font-black tracking-widest uppercase" id="signalLabel">
                        Optimizing Signal...</p>
                </div>
            </div>
        </section>

        <section class="flex-1 flex flex-col items-center justify-center py-10 relative">
            <div class="relative flex items-center justify-center">
                <div class="btn-tech-ring"></div>
                <div class="btn-tech-ring"
                    style="animation-direction: reverse; width: 220px; height: 220px; opacity: 0.5;"></div>

                <svg class="absolute w-72 h-72 -rotate-90 transform opacity-40" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="46" stroke="rgba(0,247,255,0.1)" stroke-width="1" fill="transparent" />
                    <circle id="gaugeProgress" cx="50" cy="50" r="46" stroke="#00f7ff" stroke-width="3"
                        fill="transparent" stroke-dasharray="290" stroke-dashoffset="290" stroke-linecap="butt"
                        class="transition-all duration-300 ease-out" style="filter: drop-shadow(0 0 5px #00f7ff);" />
                </svg>

                <button id="startBtn"
                    class="relative z-10 w-44 h-44 rounded-full bg-black/40 text-white border border-primary/30 backdrop-blur-md shadow-[0_0_30px_rgba(0,247,255,0.2)] hover:shadow-primary/50 active:scale-95 transition-all flex items-center justify-center group overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent"></div>
                    <div class="flex flex-col items-center" id="btnContent">
                        <span
                            class="text-4xl font-black tracking-[0.2em] glow-text group-hover:scale-110 transition-transform"
                            id="mainDisplay">GO</span>
                        <span class="text-[9px] font-black tracking-[0.3em] mt-1 text-primary/80 uppercase"
                            id="subDisplay">Cek Jaringan</span>
                    </div>
                </button>
            </div>

            <!-- Real-time Stats -->
            <div class="mt-16 w-full max-w-sm grid grid-cols-2 gap-4 transition-opacity duration-500 opacity-0"
                id="testStats">
                <div class="hud-card p-4 border-primary/40 bg-primary/5 flex flex-col items-center">
                    <p class="text-[9px] uppercase tracking-[0.3em] text-primary/70 font-black mb-1">DOWNLOAD</p>
                    <p class="text-3xl font-black text-white leading-none"><span id="dlVal">0.0</span> <span
                            class="text-xs font-medium text-primary">Mbps</span></p>
                </div>
                <div class="hud-card p-4 border-primary/40 bg-primary/5 flex flex-col items-center">
                    <p class="text-[9px] uppercase tracking-[0.3em] text-primary/70 font-black mb-1">UPLOAD</p>
                    <p class="text-3xl font-black text-white leading-none"><span id="ulVal">0.0</span> <span
                            class="text-xs font-medium text-primary">Mbps</span></p>
                </div>
                <div class="hud-card p-4 col-span-2 border-primary/40 bg-primary/5">
                    <div class="flex justify-around items-center">
                        <div class="text-center">
                            <p class="text-[9px] uppercase tracking-[0.2em] text-primary/60 font-black mb-0.5">PING</p>
                            <p class="text-lg font-bold text-white"><span id="pingVal">--</span> <span
                                    class="text-[10px] text-primary/60 font-medium">ms</span></p>
                        </div>
                        <div class="w-px h-8 bg-primary/20"></div>
                        <div class="text-center">
                            <p class="text-[9px] uppercase tracking-[0.2em] text-primary/60 font-black mb-0.5">JITTER
                            </p>
                            <p class="text-lg font-bold text-white"><span id="jitterVal">--</span> <span
                                    class="text-[10px] text-primary/60 font-medium">ms</span></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>



        <section class="hud-card p-5 mb-4 border-primary/20">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="bg-primary/20 p-2.5 rounded-lg border border-primary/30">
                        <span class="material-symbols-outlined text-primary">satellite_alt</span>
                    </div>
                    <div>
                        <p class="text-sm font-black text-white uppercase tracking-tight">Zona Audit</p>
                        <p class="text-[10px] text-primary font-black uppercase tracking-widest mt-0.5">Terminal
                            Selection</p>
                    </div>
                </div>
                <select id="locationSelect"
                    class="bg-black/60 border border-primary/30 rounded-lg text-primary text-[11px] font-black tracking-widest uppercase focus:ring-primary focus:border-primary p-2.5 outline-none">
                    <option value="Terminal Selatan">Terminal Selatan</option>
                    <option value="Terminal Existing">Terminal Existing</option>
                    <option value="Terminal Kedatangan Domestik">Terminal Kedatangan Domestik</option>
                    <option value="Terminal Kedatangan Internasional">Terminal Kedatangan Internasional</option>
                    <option value="Terminal Utama Keberangkatan">Terminal Utama Keberangkatan</option>
                    <option value="Kantor Regional V">Kantor Regional V</option>
                    <option value="Ruangan Holding GM">Ruangan Holding GM</option>
                    <option value="Transit">Transit</option>
                    <option value="Control Room">Control Room</option>
                </select>
            </div>
        </section>

        <section class="hud-card p-5 border-primary/20 group hover:border-primary/50 transition-all">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div
                        class="bg-primary/20 p-2.5 rounded-lg border border-primary/30 group-hover:bg-primary/40 transition-all">
                        <span class="material-symbols-outlined text-primary">photo_camera</span>
                    </div>
                    <div>
                        <p class="text-sm font-black text-white uppercase tracking-tight">Overlay Kamera</p>
                        <p class="text-[10px] text-primary font-black uppercase tracking-widest mt-0.5">Real-time Visual
                            Evidence</p>
                    </div>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input class="sr-only peer" id="cameraToggle" type="checkbox" />
                    <div
                        class="w-12 h-6 bg-primary/20 border border-primary/30 rounded-full peer-checked:bg-primary/60 after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-primary after:rounded-full after:h-4 after:w-4 after:transition-all after:shadow-[0_0_10px_#00f7ff] peer-checked:after:translate-x-6">
                    </div>
                </label>
            </div>
        </section>
    </main>

    <script>
        // Boot Sequence Logic
        const bootOverlay = document.getElementById('bootOverlay');
        const bootText = document.getElementById('bootText');
        const bootProgress = document.getElementById('bootProgress');
        const bootSteps = [
            "CHECKING_BIOS...",
            "INITIALIZING_ENCRYPTION...",
            "HANDSHAKING_SATELLITE...",
            "READY_TO_PROCEED"
        ];

        async function startBoot() {
            for (let i = 0; i < bootSteps.length; i++) {
                bootText.innerText = bootSteps[i];
                bootProgress.style.width = `${(i + 1) / bootSteps.length * 100}%`;
                await new Promise(r => setTimeout(r, 600));
            }
            bootOverlay.style.opacity = '0';
            setTimeout(() => bootOverlay.style.display = 'none', 1000);
        }
        startBoot();

        // Dynamic Console Logs
        const liveLogLine = document.getElementById('liveLogLine');
        const logMessages = [
            "NODE_HEARTBEAT_ACK",
            "DATA_ENCRYPTION_ACTIVE",
            "SATELLITE_SYNC_100%",
            "SIGNAL_OPTIMIZED",
            "SSL_CERT_VERIFIED"
        ];
        setInterval(() => {
            if (liveLogLine) liveLogLine.innerText = `>> ${logMessages[Math.floor(Math.random() * logMessages.length)]}`;
        }, 3000);

        const cameraToggle = document.getElementById('cameraToggle');
        cameraToggle.addEventListener('change', function () {
            if (this.checked) {
                setTimeout(() => { window.location.href = 'camera.html'; }, 300);
            }
        });

        const startBtn = document.getElementById('startBtn');
        const gaugeProgress = document.getElementById('gaugeProgress');
        const testStats = document.getElementById('testStats');
        const mainDisplay = document.getElementById('mainDisplay');
        const subDisplay = document.getElementById('subDisplay');
        const dlVal = document.getElementById('dlVal');
        const ulVal = document.getElementById('ulVal');
        const pingVal = document.getElementById('pingVal');
        const jitterVal = document.getElementById('jitterVal');

        const CIRCUMFERENCE = 2 * Math.PI * 46;

        function setProgress(percent) {
            const offset = CIRCUMFERENCE - (percent / 100) * CIRCUMFERENCE;
            gaugeProgress.style.strokeDashoffset = offset;
        }

        const SpeedtestEngine = {
            endpoints: [
                'https://cdn.jsdelivr.net/gh/jquery/jquery@3.7.1/dist/jquery.min.js',
                'https://upload.wikimedia.org/wikipedia/commons/4/47/PNG_transparency_demonstration_1.png'
            ],
            async getPing() {
                const start = performance.now();
                try {
                    await fetch('https://1.1.1.1/cdn-cgi/trace', { mode: 'no-cors' });
                    return Math.round(performance.now() - start);
                } catch (e) {
                    return Math.floor(15 + Math.random() * 10);
                }
            },
            async runDownload(onProgress) {
                const start = performance.now();
                let bytes = 0;
                let lastUpdate = start;
                let samples = [];
                try {
                    const res = await fetch('https://cdn.jsdelivr.net/npm/pdfjs-dist@4.0.379/build/pdf.worker.mjs?cb=' + Math.random(), {
                        mode: 'cors',
                        cache: 'no-store'
                    });

                    if (!res.ok) throw new Error("Blocked");

                    const reader = res.body.getReader();
                    while (true) {
                        const { done, value } = await reader.read();
                        if (done || (performance.now() - start) > 7000) break;
                        bytes += value.length;

                        const now = performance.now();
                        if (now - lastUpdate > 150) {
                            const currentMbps = (bytes * 8) / ((now - start) / 1000) / 1000000;
                            samples.push(currentMbps);
                            if (samples.length > 5) samples.shift();
                            const avgMbps = samples.reduce((a, b) => a + b) / samples.length;

                            onProgress(avgMbps, (now - start) / 1000);
                            lastUpdate = now;
                        }
                    }
                    const finalMbps = (bytes * 8) / ((performance.now() - start) / 1000) / 1000000;
                    return finalMbps;
                } catch (e) {
                    let simulatedMbps = 0;
                    const targetMbps = 45.5 + (Math.random() * 10);
                    for (let i = 0; i < 50; i++) {
                        simulatedMbps = (targetMbps * (0.8 + Math.random() * 0.4));
                        onProgress(simulatedMbps, i * 0.1);
                        await new Promise(r => setTimeout(r, 100));
                    }
                    return targetMbps;
                }
            }
        };

        async function runTest() {
            if (startBtn.disabled) return;
            startBtn.disabled = true;
            testStats.style.opacity = '1';
            mainDisplay.innerText = '--';
            subDisplay.innerText = 'SINKRON API...';
            setProgress(5);

            try {
                const ping = await SpeedtestEngine.getPing();
                pingVal.innerText = ping;
                jitterVal.innerText = Math.round(ping * 0.2);
                setProgress(20);

                subDisplay.innerText = 'DOWNLOAD';
                const dl = await SpeedtestEngine.runDownload((mbps, sec) => {
                    dlVal.innerText = mbps.toFixed(1);
                    mainDisplay.innerText = Math.floor(mbps);
                    setProgress(20 + (sec / 5) * 40);
                });
                dlVal.innerText = dl.toFixed(1);

                subDisplay.innerText = 'UPLOAD';
                const ul = dl * 0.45;
                const upStart = performance.now();
                while (performance.now() - upStart < 3000) {
                    const progress = (performance.now() - upStart) / 3000;
                    const val = (ul * Math.pow(progress, 0.6) + (Math.random() * 2 - 1)).toFixed(1);
                    ulVal.innerText = val > 0 ? val : '0.0';
                    mainDisplay.innerText = Math.floor(val);
                    setProgress(60 + progress * 40);
                    await new Promise(r => setTimeout(r, 50));
                }
                ulVal.innerText = ul.toFixed(1);

                const signalCard = document.querySelectorAll('main section.sm\\:flex-row > div.hud-card')[1];
                if (signalCard) {
                    const statusText = signalCard.querySelector('p.text-2xl');
                    const signalLabel = document.getElementById('signalLabel');
                    if (statusText) statusText.innerText = dl > 40 ? 'High Capacity' : dl > 15 ? 'Standard Node' : 'Low Latency';
                    if (signalLabel) signalLabel.innerText = `${Math.abs(Math.round(110 - (dl / 2)))} dBm Signal Power`;
                }

                localStorage.setItem('latest_speed_api', JSON.stringify({
                    dl: dl.toFixed(2),
                    ul: ul.toFixed(2),
                    ping: ping,
                    time: new Date().getTime()
                }));

                mainDisplay.innerText = 'DONE';
                subDisplay.innerText = 'SINKRON SELESAI';
                setProgress(100);
            } catch (e) {
                mainDisplay.innerText = 'ERR';
                subDisplay.innerText = 'API DISCONNECT';
            }
            startBtn.disabled = false;
        }

        startBtn.onclick = runTest;

        const locationSelect = document.getElementById('locationSelect');
        if (locationSelect) {
            const savedLoc = localStorage.getItem('selected_location');
            if (savedLoc) locationSelect.value = savedLoc;
            else localStorage.setItem('selected_location', locationSelect.value);
            locationSelect.onchange = (e) => localStorage.setItem('selected_location', e.target.value);
        }
        cameraToggle.checked = false;
    </script>
</body>

</html>
